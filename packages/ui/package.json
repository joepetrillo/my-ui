  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run generate:api && tsup src/index.ts src/components/*.tsx src/hooks/*.ts src/lib/*.ts src/base-ui/*.ts --format esm --dts --sourcemap --clean --external @my-ui/ui --external @my-ui/ui/*",
    "check:api": "tsx scripts/generate-public-api.ts --check",
    "clean": "rm -rf dist *.tsbuildinfo",
    "generate:api": "tsx scripts/generate-public-api.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.555.0",
    "react-day-picker": "^9.13.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.6"
  },
  "peerDependencies": {
    "react": ">=18.3.0",
    "react-dom": ">=18.3.0"

{
  "name": "@my-ui/ui",
  "version": "0.1.0",
  "description": "A Base UI and Tailwind CSS component system with live-editable design tokens.",
  "license": "MIT",
  "files": [
    "dist",
    "src/styles"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./base-ui/*": {
      "types": "./dist/base-ui/*.d.ts",
      "import": "./dist/base-ui/*.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    },
    "./globals.css": "./src/styles/globals.css",
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "import": "./dist/hooks/*.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js"
    },
    "./styles/globals.css": "./src/styles/globals.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/components/*.tsx src/hooks/*.ts src/lib/*.ts src/base-ui/*.ts --format esm --dts --sourcemap --clean --external @my-ui/ui --external @my-ui/ui/*",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.555.0",
    "react-day-picker": "^9.13.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.6"
  },
  "peerDependencies": {
    "react": ">=18.3.0",
    "react-dom": ">=18.3.0"
  }
}

{
  "$schema": "https://react.doctor/schema/config.json",
  "ignore": {
    "overrides": [
      {
        // `InlineScript` is a no-flash theme bootstrap: developer-authored
        // inline JS (no user input) that must execute synchronously *before*
        // hydration via the server-only `text/javascript` type, which
        // `next/script` cannot replicate. Injecting inline script content in
        // React requires `dangerouslySetInnerHTML`.
        //
        // The color swatches use `role="img"` with an `aria-label`: they are
        // CSS background-color previews with no raster source, and the project
        // lint (next/no-img-element) disallows a raw `<img>` here, so the ARIA
        // role is the correct accessible representation.
        "files": ["app/sandbox.tsx"],
        "rules": [
          "react-doctor/nextjs-no-native-script",
          "react-doctor/dangerous-html-sink",
          "react-doctor/prefer-tag-over-role"
        ]
      }
    ]
  }
}

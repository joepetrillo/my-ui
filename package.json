{
  "name": "my-ui-workspace",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run build:ui && bun run build:sandbox",
    "build:sandbox": "bun run --filter @my-ui/sandbox build",
    "build:ui": "bun run --filter @my-ui/ui build",
    "dev": "bun run --parallel dev:ui dev:sandbox",
    "dev:sandbox": "bun run --cwd apps/sandbox dev",
    "dev:ui": "bun run --cwd packages/ui dev",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "typecheck": "bun run --workspaces --if-present typecheck",
    "fix": "ultracite fix",
    "check": "bun run --filter @my-ui/ui check:api && ultracite check"
  },
  "devDependencies": {
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "ultracite": "^7.8.3"
  },
  "packageManager": "bun@1.3.14"
}
